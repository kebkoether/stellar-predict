# Server Configuration
NODE_ENV=development
SERVER_PORT=3000
WS_PORT=3001

# Database
DB_PATH=./data.db

# Stellar Network Configuration
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Settlement Account (secret key for signing transactions)
# WARNING: Never commit real keys! Use a dedicated settlement account
SETTLEMENT_KEYPAIR=SBXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# USDC Asset Configuration
# For testnet, using standard testnet USDC issuer
USDC_ASSET_CODE=USDC
USDC_ISSUER=GA5ZSEJYB37JRC5AVCIA5MOP4IYCGVS53UJVQ7RKSTD4P2WZDTAB47Z

# Settlement Pipeline
SETTLEMENT_BATCH_SIZE=100
SETTLEMENT_INTERVAL_MS=10000
SETTLEMENT_RETRY_INTERVAL_MS=30000
SETTLEMENT_MAX_RETRIES=5

# Logging
LOG_LEVEL=info
